{
  "name": "shopify_connector",
  "version": "1.4.2",
  "type": "connector",
  "category": "ecommerce",
  "description": "Shopify OAuth connector for syncing orders, products, and customers. Supports real-time webhooks.",
  "author": "MailPilot",
  "enabled": false,
  "multiTenant": true,
  "supports_oauth": true,
  "supports_api_key": false,
  "supports_webhook": true,
  "queue_enabled": true,
  "oauth_provider": "shopify",
  "oauth_scopes": [
    "read_orders",
    "write_orders",
    "read_products",
    "write_products",
    "read_customers",
    "read_inventory"
  ],
  "permissions": ["orders.read", "orders.write", "products.read", "customers.read", "inventory.read"],
  "events": [
    "order.created",
    "order.updated",
    "order.fulfilled",
    "order.cancelled",
    "order.refunded",
    "product.created",
    "product.updated",
    "product.deleted"
  ],
  "webhook_events": ["orders/create", "orders/updated", "orders/fulfilled", "orders/cancelled", "products/create", "products/update"],
  "config_schema": {
    "shop": {"type": "string", "required": true, "description": "Shopify store handle (e.g. mystore)"},
    "api_key": {"type": "string", "required": true, "source": "env:SHOPIFY_API_KEY"},
    "api_secret": {"type": "secret", "required": true, "source": "env:SHOPIFY_API_SECRET"},
    "redirect_uri": {"type": "string", "required": true}
  }
}
