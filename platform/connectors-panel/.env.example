# ============================================================
# MailPilot Connector & Plugin Panel — Environment Variables
# Copy this file to .env and fill in the required values.
# NEVER commit the .env file to source control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Path to the SQLite database file.
# Default: platform/connectors_panel.db (relative to project root)
CONNECTOR_PANEL_DB_PATH=./platform/connectors_panel.db

# ------------------------------------------------------------
# Encryption
# ------------------------------------------------------------
# Fernet symmetric encryption key for storing OAuth tokens and webhook secrets.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production.
CONNECTOR_PANEL_ENCRYPTION_KEY=

# Default webhook signing secret (used when no per-webhook secret is provided)
CONNECTOR_PANEL_WEBHOOK_SECRET=

# ------------------------------------------------------------
# WhatsApp Business API
# ------------------------------------------------------------
# Meta System User Access Token (from Meta Developer Console)
WHATSAPP_API_KEY=

# Phone Number ID (from WhatsApp Business Account settings)
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Token used for Meta webhook subscription verification
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# App Secret for HMAC signature verification
WHATSAPP_APP_SECRET=

# ------------------------------------------------------------
# Gmail / Google OAuth
# ------------------------------------------------------------
# Google OAuth 2.0 client credentials (from Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# OAuth redirect URI (must match Google Cloud Console configuration)
GMAIL_REDIRECT_URI=http://localhost:8000/api/connector-panel/oauth/callback/google

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
OPENAI_API_KEY=

# Optional: override the default model
OPENAI_MODEL=gpt-4o-mini

# Optional: Organization ID
OPENAI_ORGANIZATION_ID=

# ------------------------------------------------------------
# Shopify
# ------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Your Shopify store handle (e.g. "mystore" for mystore.myshopify.com)
SHOPIFY_SHOP=

SHOPIFY_REDIRECT_URI=http://localhost:8000/api/connector-panel/oauth/callback/shopify

# ------------------------------------------------------------
# Slack
# ------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Slack App Signing Secret for webhook signature verification
SLACK_SIGNING_SECRET=

SLACK_REDIRECT_URI=http://localhost:8000/api/connector-panel/oauth/callback/slack

# ------------------------------------------------------------
# HubSpot CRM
# ------------------------------------------------------------
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/api/connector-panel/oauth/callback/hubspot

# ------------------------------------------------------------
# Microsoft (Office 365 / Outlook)
# ------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/connector-panel/oauth/callback/microsoft

# ------------------------------------------------------------
# OCR Engine
# ------------------------------------------------------------
# Set to: internal | google_vision | aws_textract | azure_form_recognizer
OCR_ENGINE=internal

# Google Cloud Vision API key (required if OCR_ENGINE=google_vision)
GOOGLE_VISION_API_KEY=

# AWS credentials (required if OCR_ENGINE=aws_textract)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure Form Recognizer (required if OCR_ENGINE=azure_form_recognizer)
AZURE_OCR_KEY=
AZURE_OCR_ENDPOINT=

# ------------------------------------------------------------
# Generic Webhook Listener
# ------------------------------------------------------------
# Shared HMAC secret for the generic webhook listener
WEBHOOK_LISTENER_SECRET=

# ------------------------------------------------------------
# ERP Sync
# ------------------------------------------------------------
ERP_API_KEY=
ERP_API_URL=

# ------------------------------------------------------------
# Zoho CRM
# ------------------------------------------------------------
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:8000/api/connector-panel/oauth/callback/zoho

# ------------------------------------------------------------
# Shipping Tracker
# ------------------------------------------------------------
FEDEX_API_KEY=
UPS_API_KEY=
DHL_API_KEY=
USPS_API_KEY=
