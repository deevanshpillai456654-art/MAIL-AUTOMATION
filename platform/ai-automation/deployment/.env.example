# AI Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2

# Database paths
AI_AUTOMATION_DB_PATH=/data/ai_automation.db
CONNECTOR_PANEL_DB_PATH=/data/connectors_panel.db

# Worker
WORKER_POLL_INTERVAL=5

# Security
SECRET_KEY=change-me-in-production-32chars+

# External integrations (optional)
ERP_WEBHOOK_URL=https://your-erp.example.com/webhook
ACCOUNTING_API_URL=https://your-accounting.example.com/api
