# Runtime
LOCAL_FIRST_ENTERPRISE_MODE=1
APP_ENV=production
CONTAINERIZED=true
API_HOST=0.0.0.0
API_PORT=4597
PUBLIC_BASE_URL=https://mailops.example.com
CORS_ALLOWED_ORIGINS=https://mailops.example.com,chrome-extension://YOUR_EXTENSION_ID
LOG_LEVEL=INFO

# Database / queue
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+psycopg://aiemail:replace-with-strong-password@postgres:5432/aiemail
REDIS_URL=redis://redis:6379/0
QUEUE_BACKEND=redis
DEAD_LETTER_QUEUE_URL=redis://redis:6379/1

# Secrets / vault
VAULT_PROVIDER=hashicorp
VAULT_ADDR=https://vault.example.com
TOKEN_ENCRYPTION_KEY=replace-with-fernet-key-from-vault
# Connector Panel — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_PANEL_ENCRYPTION_KEY=replace-with-fernet-key-from-vault

# OAuth providers
GMAIL_CLIENT_ID=replace-with-google-client-id
GMAIL_CLIENT_SECRET=replace-with-google-client-secret
GMAIL_REDIRECT_URI=https://mailops.example.com/api/oauth/google/callback
OUTLOOK_CLIENT_ID=replace-with-azure-client-id
OUTLOOK_CLIENT_SECRET=replace-with-azure-client-secret
OUTLOOK_REDIRECT_URI=https://mailops.example.com/api/oauth/microsoft/callback
OUTLOOK_TENANT_ID=common

# Observability / ops
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com/v1/traces
SENTRY_DSN=https://public@example.ingest.sentry.io/project
BACKUP_BUCKET=s3://aiemail-prod-backups
K8S_REPLICAS=3

# Compliance / marketplace
PRIVACY_POLICY_URL=https://mailops.example.com/privacy
TERMS_URL=https://mailops.example.com/terms
DPA_URL=https://mailops.example.com/dpa
SUPPORT_URL=https://mailops.example.com/support

# Security hardening
REQUIRE_REQUEST_SIGNATURES=true
REQUEST_SIGNING_SECRET=replace-with-strong-hmac-secret-from-vault
REQUEST_SIGNING_WINDOW_SECONDS=300
MAX_REQUEST_BODY_BYTES=1048576
SECURITY_AUDIT_LOG=/app/logs/security-audit.jsonl
SECURITY_AUDIT_BUFFER=1000
ALLOW_INSECURE_WEBHOOKS=false
ALLOW_PRIVATE_WEBHOOKS=false

# Provider OAuth setup
# These can also be saved securely from http://127.0.0.1:4597/setup
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
