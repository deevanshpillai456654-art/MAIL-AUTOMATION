# AI Email Organizer - Environment Configuration
# Copy this to .env and fill in your values

# API Configuration
LOCAL_FIRST_ENTERPRISE_MODE=1
API_HOST=127.0.0.1
API_PORT=4597

# Logging
LOG_LEVEL=INFO

# Database
# Leave DB_PATH unset for normal Windows installs. The app stores accounts in:
#   %LOCALAPPDATA%\AIEmailOrganizer\data\emails.db
# Advanced override only: set AIO_DATA_DIR or DB_PATH to an absolute durable path when needed.

# OAuth - Gmail (get from Google Cloud Console)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret

# OAuth - Outlook (get from Azure Portal)
OUTLOOK_CLIENT_ID=your_outlook_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret
OUTLOOK_TENANT_ID=common

# Security
SECRET_KEY=change_this_to_random_string

# Features
ENABLE_NOTIFICATIONS=true
ENABLE_WEBHOOKS=false
ENABLE_SCHEDULER=true

# Model Settings
# Leave MODEL_PATH unset for normal Windows installs. Use AIO_MODEL_DIR for an explicit durable path.
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Security hardening
REQUIRE_REQUEST_SIGNATURES=false
REQUEST_SIGNING_SECRET=
REQUEST_SIGNING_WINDOW_SECONDS=300
MAX_REQUEST_BODY_BYTES=1048576
SECURITY_AUDIT_LOG=
SECURITY_AUDIT_BUFFER=500
ALLOW_INSECURE_WEBHOOKS=false
ALLOW_PRIVATE_WEBHOOKS=false

# Provider OAuth setup
# These can also be saved securely from http://127.0.0.1:4597/setup
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
